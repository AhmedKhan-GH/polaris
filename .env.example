# PostgreSQL connection (local Supabase default: postgresql://postgres:postgres@127.0.0.1:54322/postgres)
DATABASE_URL=

# Supabase project URL and anon (publishable) key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Playwright E2E test user (must exist in local Supabase Auth).
# Create via Supabase Studio at http://127.0.0.1:54323 -> Authentication -> Users.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
