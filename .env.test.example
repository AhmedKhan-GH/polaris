# Copy to .env.test and fill in values
AUTH_KEYCLOAK_ID=polaris-web
AUTH_KEYCLOAK_SECRET=polaris-dev-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/polaris
AUTH_SECRET=
AUTH_TRUST_HOST=true
TEST_USER_EMAIL=owner@example.com
TEST_USER_PASSWORD=test-password-123
# Isolated, ephemeral E2E database — a throwaway Postgres on its own port
# (NOT the dev DB). global-setup spins it, migrates as the admin URL, and makes
# app_user a LOGIN role. The app connects as the non-superuser app_user
# (DATABASE_URL); migrations use the privileged admin (MIGRATE_DATABASE_URL).
DATABASE_URL=postgresql://app_user:apppw@127.0.0.1:54399/postgres
MIGRATE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54399/postgres
