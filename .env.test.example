# Copy to .env.test and fill in values
TEST_USER_EMAIL=owner@example.com
TEST_USER_PASSWORD=test-password-123
# Local Supabase (run `supabase start`, then `supabase status -o env`).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# App connects as the non-superuser app_user (DATABASE_URL); migrations use the
# privileged admin (MIGRATE_DATABASE_URL).
DATABASE_URL=postgresql://app_user:apppw@127.0.0.1:54322/postgres
MIGRATE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
